{
    "version": 2,
    "buildCommand": "echo 'skip'",
    "framework": null,
    "functions": {
        "public/index.php": {
            "runtime": "vercel-php@0.7"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.php"
        }
    ]
}